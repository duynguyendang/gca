# Required for Embeddings and AI Analysis
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3-flash-preview

# Optional: Server Configuration
PORT=8080

# Optional: Logging Configuration
# Log level: DEBUG, INFO, WARN, ERROR (default: INFO)
LOG_LEVEL=INFO

# Optional: CORS Configuration
# Comma-separated list of allowed origins for Cross-Origin Resource Sharing
# Example: CORS_ALLOW_ORIGINS=https://example.com,https://app.example.com
# Default (if not set): http://localhost:3000,http://localhost:5173,http://localhost:8080
CORS_ALLOW_ORIGINS=

# Optional: Enable low-memory optimization (true/false)
# Useful for environments with limited RAM (e.g., Cloud Run 1GB)
LOW_MEM=false
